{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "strict": true,
    "types": ["node", "@azure/functions"],
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": ".",
    "ignoreDeprecations": "5.0"
  },
  "include": ["**/*.ts"]
}
